    create table "iceberg"."silver"."silver_test"
      
      
    as (
      

with source as (
    select * from "iceberg"."bronze"."bronze_test"
),

cleaned as (
    select
        id,
        array_join(
            transform(
                split(trim(name), ' '),
                word -> upper(substr(word, 1, 1)) || lower(substr(word, 2))
            ),
            ' '
        )                               as name,
        age,
        array_join(
            transform(
                split(trim(city), ' '),
                word -> upper(substr(word, 1, 1)) || lower(substr(word, 2))
            ),
            ' '
        )                               as city,
        case
            when age < 18               then 'minor'
            when age between 18 and 64  then 'adult'
            else                             'senior'
        end                             as age_group,
        _ingested_at,
        _source_table
    from source
    where name is not null
      and age > 0
)

select * from cleaned
    )
