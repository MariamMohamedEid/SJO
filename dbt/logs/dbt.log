    j.rank_en,
    j.specialization,
    j.specialization_en,
    j.court_level,
    a.assigned_court_id,
    a.assigned_circuit_id,
    a.assigned_from,
    a.role as assignment_role
from judges j
left join assignments a
    on j.judge_id = a.judge_id
  
