    create table "iceberg"."bronze_silver"."silver_test"
      
      WITH (format = 'PARQUET',
  location = 's3a://iceberg/silver/silver_test/')
    as (
      

with source as (
    select * from "iceberg"."bronze_bronze"."bronze_test"
),

cleaned as (
    select
        id,
        initcap(trim(name))             as name,
        age,
        initcap(trim(city))             as city,
        case
            when age < 18               then 'minor'
            when age between 18 and 64  then 'adult'
            else                             'senior'
        end                             as age_group,
        _ingested_at,
        _source_table
    from source
    where name is not null
      and age > 0
)

select * from cleaned
    )
